# ── funduqii backend — نموذج متغيّرات البيئة ──────────────────────────────
# انسخه إلى backend/.env (أو اضبطه في بيئة الاستضافة). لا ترفع .env الحقيقي إلى Git.

# ── الأساسيات (إلزامية على الإنتاج) ──────────────────────────────────────
DJANGO_DEBUG=false
# مفتاح عشوائي طويل (>=50 حرفًا). توليده:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=funduqii.com,api.funduqii.com

# ── قاعدة البيانات ──────────────────────────────────────────────────────
# إن غابت → SQLite (تطوير فقط). على الإنتاج استخدم PostgreSQL:
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/funduqii

# ── CORS / CSRF ─────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=https://funduqii.com
CSRF_TRUSTED_ORIGINS=https://funduqii.com,https://api.funduqii.com

# ── هوية المنصّة الافتراضية (تُدار ديناميكيًا لاحقًا من لوحة المنصّة) ──────
PLATFORM_NAME=funduqii

# ── البريد (اختياري — بدونه تُطبع الرسائل في الطرفية) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=funduqii <no-reply@funduqii.com>

# ── SMS / WhatsApp (اختياري) ────────────────────────────────────────────
SMS_PROVIDER=
SMS_FROM=funduqii
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=

# ── البذر (تطوير فقط) ───────────────────────────────────────────────────
# يُرفض seed_users على الإنتاج إلا بضبط ALLOW_SEED=1 صراحةً (يُضاف في المرحلة 2).
# ALLOW_SEED=1
